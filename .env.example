# ── Stockyard Environment Variables ──────────────
# Copy to .env and fill in your values.

# Admin key (protects management API, required in production)
STOCKYARD_ADMIN_KEY=

# License key (Pro/Cloud/Enterprise — omit for Community tier)
STOCKYARD_LICENSE_KEY=

# Port (default: 4200)
PORT=4200

# Require API keys for proxy access (default: false)
STOCKYARD_REQUIRE_AUTH=false

# ── Provider API Keys ────────────────────────────
# Set at least one. Stockyard auto-detects providers from key prefixes.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=

# Azure OpenAI (requires endpoint + key)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ── OpenTelemetry ────────────────────────────────
# Set to export traces to any OTLP-compatible backend.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=stockyard
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer token

# ── Logging ──────────────────────────────────────
# LOG_LEVEL=info     # debug, info, warn, error
# LOG_FORMAT=text    # text or json
